# Copy this file to .env.local and fill in your values.

# Point to the same backend as AstroTalks (default: http://localhost:5000)
VITE_API_BASE_URL=http://localhost:5000

# Set to "true" to skip the real API and use built-in mock responses.
# Useful for UI testing or demos when the backend is not running.
VITE_MOCK_API=true
