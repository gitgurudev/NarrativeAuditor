# Copy to .env and fill in values — never commit .env

# MongoDB Atlas connection string (same as AstroTalks)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/narrativeauditor

# JWT secret — any long random string
JWT_SECRET=change_this_to_a_long_random_secret_string

# Gmail credentials for email alerts
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx   # Gmail App Password (16 chars, no spaces)

# Your deployed frontend URL (for CORS)
FRONTEND_URL=https://narrativeauditor.onrender.com

# Port (Render sets this automatically)
PORT=5001
