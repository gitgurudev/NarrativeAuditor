# Copy this to .env and fill in your values
# .env is gitignored — never commit real keys

# Set to "true" to run fully offline with mock data (no API key needed)
VITE_MOCK_API=true

# Your backend API base URL (only needed when VITE_MOCK_API=false)
# API keys must live on the backend — never put them here directly
VITE_API_BASE_URL=http://localhost:5000
